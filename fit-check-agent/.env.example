# Local profile bundle directory. Relative paths resolve from fit-check-agent/.
FIT_CHECK_PROFILES_DIR=profiles

# ChatGPT web automation knobs.
CHATGPT_URL=https://chatgpt.com/
CHATGPT_WAIT_SECONDS=3
CHATGPT_IMAGE_SETTLE_SECONDS=3
CHATGPT_FINAL_SETTLE_SECONDS=6
CHATGPT_SUBMIT_ATTEMPTS=6
CHATGPT_SUBMIT_RETRY_SECONDS=2

# Product context cleanup. Uses the workspace/root OPENROUTER_API_KEY when set.
FIT_CHECK_CLEAN_PRODUCT_CONTEXT=true
FIT_CHECK_CLEANER_MAX_ATTEMPTS=5

FIT_CHECK_REQUEST_TIMEOUT_SECONDS=20

# Product image fetcher. The agent downloads "original" product image URLs
# (those without Cloudinary-style transform params in the path) and uploads
# them to ChatGPT instead of asking the model to fetch URLs.
FIT_CHECK_PRODUCT_IMAGE_MAX_COUNT=6
FIT_CHECK_PRODUCT_IMAGE_MAX_BYTES=8388608

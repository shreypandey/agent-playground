# =============================================================================
# Shared keys for all agents in this workspace.
# Copy to `.env` (gitignored) and fill in. Individual agents may override any
# of these in their own `<agent>/.env` file — agent values win over root.
# =============================================================================

# OpenRouter (LLM gateway). Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-...
OPENROUTER_MODEL=anthropic/claude-haiku-4.5
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# =============================================================================
# Agent-specific config for hn-job-agent.
# Shared LLM keys (OPENROUTER_*) live in ../.env at the workspace root.
# Any key set here OVERRIDES the same key set in ../.env (use this to pin a
# different model or key for just this agent).
# =============================================================================

# Telegram — required. TELEGRAM_CHAT_IDS accepts a single id or comma-separated
# list (e.g. "6682397806,-1001234567890"). TELEGRAM_CHAT_ID (singular) is also
# accepted for backwards compatibility.
TELEGRAM_BOT_TOKEN=123456:ABC-...
TELEGRAM_CHAT_IDS=123456789

# Filtering
MIN_SALARY_INR_LPA=50
USD_TO_INR_FALLBACK=90.0          # only used if Frankfurter API fails

# Notification rate cap. 0 disables the cap (every match is sent each run).
MAX_NOTIFICATIONS_PER_RUN=0

# Optional per-agent override of the shared LLM model
# OPENROUTER_MODEL=anthropic/claude-haiku-4.5
